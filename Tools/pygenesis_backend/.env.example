# Copia a `.env` en esta carpeta. No subas `.env` al repositorio.
#
# Stack local: Ollama + pygenesis-unity (ver Tools/ollama/README.md)

# --- Análisis (/analyze-selection) ---
PYGENESIS_REASONING_MODE=hybrid
PYGENESIS_COMPACT_LLM_PROMPT=true

# --- Puente PyGenesis (llama-server, sin Ollama) ---
# PYGENESIS_LLM_PROVIDER=pygenesis_bridge
# PYGENESIS_BRIDGE_URL=http://127.0.0.1:8081/v1
# PYGENESIS_BRIDGE_CONFIG=../pygenesis_inference/model_config.yaml
# Paridad navegador: system en ui_config.json + inyectado por el backend (defecto on)
# PYGENESIS_BRIDGE_INJECT_SYSTEM=off   # solo user (no recomendado; distinto del navegador)
# PYGENESIS_BRIDGE_MINIMAL_API=on
# PYGENESIS_CHAT_POSTPROCESS=off   # automático con pygenesis_bridge
# PYGENESIS_CHAT_PERSONA=ollama_native
# Ver Tools/pygenesis_inference/README.md

# --- Ollama + pygenesis-unity (referencia A/B) ---
PYGENESIS_LLM_PROVIDER=ollama
PYGENESIS_LLM_MODEL=pygenesis-unity:latest
PYGENESIS_LLM_BASE_URL=http://127.0.0.1:11434/v1
PYGENESIS_LLM_API_KEY_ENV=OPENAI_API_KEY
OPENAI_API_KEY=dummy
PYGENESIS_LLM_USE_JSON_RESPONSE_FORMAT=false
PYGENESIS_LLM_TIMEOUT_SECONDS=600
PYGENESIS_LLM_MAX_TOKENS=1024
PYGENESIS_LLM_TEMPERATURE=0.2
PYGENESIS_LLM_REPEAT_PENALTY=1.30
PYGENESIS_OLLAMA_REASONING_EFFORT=none
# PYGENESIS_OLLAMA_STOP=none
PYGENESIS_STRIP_REDACTED_THINKING=false

# --- Chat (/chat) ---
# builtin | modelfile | ollama_native (system mínimo; persona en Modelfile Ollama)
PYGENESIS_CHAT_PERSONA=modelfile
PYGENESIS_CHAT_DOMAIN_BLOCKS=off
PYGENESIS_LLM_CHAT_MAX_TOKENS=1536
PYGENESIS_LLM_CHAT_TEMPERATURE=0.55
PYGENESIS_CHAT_MAX_HISTORY_MESSAGES=8
PYGENESIS_CHAT_MAX_HISTORY_CHARS=12000
PYGENESIS_CHAT_MAX_SYSTEM_CHARS=48000
PYGENESIS_RAG_ENABLED=false
PYGENESIS_CHAT_KNOWLEDGE=off
# Anti-bucle: off (recomendado salvo ollama_native) | strong | full
# ollama_native activa anti-bucle en streaming aunque pongas off (ver logs).
PYGENESIS_CHAT_REPETITION_GUARD=off

# Rama alineacionOllama: probar ollama_native + historial corto (ver .env local)
# PYGENESIS_CHAT_PERSONA=ollama_native
# PYGENESIS_CHAT_MAX_HISTORY_MESSAGES=2
# PYGENESIS_CHAT_MAX_HISTORY_CHARS=4000

# Opcional: segundo pase LLM en analyze_scene (más lento)
# PYGENESIS_SCENE_TWO_PASS=1

# Opcional: omitir warmup al arrancar (tests/CI)
# PYGENESIS_LLM_SKIP_STARTUP_LOAD=true

# Reintento automático si el warmup falla (p. ej. puente aún no levantado)
# PYGENESIS_LLM_WARMUP_RETRY=on
# PYGENESIS_LLM_WARMUP_RETRY_SECONDS=15
