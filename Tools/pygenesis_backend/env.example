# Copia a `.env` en esta misma carpeta (`Tools/pygenesis_backend/.env`).
# No subas `.env` al repositorio.

# --- Proveedor LLM (openai | openai_compatible | gemini | google | ollama | local) ---
# PYGENESIS_LLM_PROVIDER=gemini

# URLs por defecto (solo si no las defines; Gemini usa la API compatible OpenAI de Google):
# PYGENESIS_LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# PYGENESIS_LLM_BASE_URL=https://api.openai.com/v1

# Modelo (ejemplos):
# PYGENESIS_LLM_MODEL=gemini-2.0-flash
# PYGENESIS_LLM_MODEL=gpt-4o-mini

# Variable de entorno donde está la API key (el backend hace os.environ[api_key_env]):
# PYGENESIS_LLM_API_KEY_ENV=GEMINI_API_KEY
# PYGENESIS_LLM_API_KEY_ENV=OPENAI_API_KEY

# GEMINI_API_KEY=tu_clave_api_google
# OPENAI_API_KEY=sk-...

# Si el análisis JSON falla con Gemini, prueba sin forzar JSON mode:
# PYGENESIS_LLM_USE_JSON_RESPONSE_FORMAT=false

# (Qwen / Ollama) false = no filtrar thinking en respuestas (depuración; ver filtrar_thinking_qwen.md)
# PYGENESIS_STRIP_REDACTED_THINKING=false

# Parámetros de muestreo (alineados con el prompt principal; num_ctx se configura en el servidor, p. ej. Ollama):
# PYGENESIS_LLM_TEMPERATURE=0.2
# PYGENESIS_LLM_TOP_P=0.9
# PYGENESIS_LLM_REPEAT_PENALTY=1.05
# (Ollama) `ollama serve` / Modelfile: PARAMETER num_ctx 8192
# (Ollama + modelos thinking, p. ej. Qwen 3) reasoning_effort en /v1/chat/completions:
# PYGENESIS_OLLAMA_REASONING_EFFORT=none
# none|low|medium|high; vacío/false/off = no enviar el campo.

# Timeout (segundos) para llamadas al LLM.
# PYGENESIS_LLM_TIMEOUT_SECONDS=120

# Reintentos si la API devuelve 429 (rate limit) o 503 (Gemini/OpenAI).
# PYGENESIS_LLM_RETRY_MAX=4
# PYGENESIS_LLM_RETRY_DELAY_SEC=2.0
